flowchart LR
    subgraph Source["Source System"]
        PG["PostgreSQL\n(Star Schema)\n~10K transactions"]
    end

    subgraph Databricks["Azure Databricks"]
        direction TB
        Bronze["Bronze Layer\nRaw + Metadata"]
        Silver["Silver Layer\nCleaned + Enriched"]
        Gold["Gold Layer\nFeature Engineering"]
        Bronze --> Silver --> Gold
    end

    subgraph Targets["Query Backends"]
        Neo4j["Neo4j\n(Graph Database)\nFraud Patterns"]
        SparkSQL["Spark SQL\n(Gold Tables)\nAggregations"]
    end

    subgraph AI["AI Layer"]
        OpenAI["Azure OpenAI\nGPT-4o"]
    end

    KV["Azure Key Vault\nCredentials & Secrets"]

    PG -- "JDBC" --> Bronze
    Gold -- "Spark Connector\n(writes)" --> Neo4j
    Gold -. "Registered as\nSQL views" .-> SparkSQL

    OpenAI -- "Generated SQL" --> SparkSQL
    OpenAI -- "Generated Cypher\n(HTTP API)" --> Neo4j

    KV -. "Secrets" .-> Databricks
    KV -. "Secrets" .-> AI

